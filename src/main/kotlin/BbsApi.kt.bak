package com.example

import io.ktor.http.*
import io.ktor.server.application.*
import io.ktor.server.request.*
import io.ktor.server.response.*
import io.ktor.server.routing.*
import java.time.LocalDateTime
import java.time.format.DateTimeFormatter
import java.util.concurrent.atomic.AtomicInteger
import kotlinx.serialization.Serializable
@Serializable
data class ThreadItem(val id: Int, val title: String, val createdAt: String)
data class PostItem(val id: Int, val threadId: Int, val name: String, val text: String, val time: String)
private val threadSeq = AtomicInteger(1)
private val postSeq = AtomicInteger(1)
private val threads = mutableListOf<ThreadItem>()
private val posts = mutableListOf<PostItem>()
private fun now(): String =
    LocalDateTime.now().format(DateTimeFormatter.ofPattern("yyyy-MM-dd HH:mm"))
fun Application.configureBbsApi() {
    routing {
        // г‚№гѓ¬дёЂи¦§
        get("/api/threads") {
            call.respond(threads)
        }
        // ж–°и¦Џг‚№гѓ¬дЅњжЃEЃEЃEext/plainгЃ§г‚‚гѓ•г‚©гѓјгѓ гЃ§г‚‚OKЃEЃE
        post("/api/threads") {
            val titleRaw = try {
                call.receiveText()
            } catch (e: Exception) {
                val p = call.receiveParameters()
                p["title"] ?: ""
            }
            val title = titleRaw.trim().ifBlank { "з„ЎйЎЊг‚№гѓ¬" }.take(40)
            val t = ThreadItem(threadSeq.getAndIncrement(), title, now())
            threads.add(t)
            call.respond(HttpStatusCode.Created, t)
        // жЉ•зЁїдёЂи¦§ЃEЃEhreadIdеїЃE €пјЃE
        get("/api/posts") {
            val threadId = call.request.queryParameters["threadId"]?.toIntOrNull()
            if (threadId == null) {
                call.respond(HttpStatusCode.BadRequest, "threadId required")
                return@get
            call.respond(posts.filter { it.threadId == threadId })
        // ж–°и¦ЏжЉ•зЁїЃE€гѓ•г‚©гѓјгѓ гЃ§еЏ—гЃ‘еЏ–г‚‹ЃEЃE
        post("/api/posts") {
            val params = call.receiveParameters()
            val threadId = params["threadId"]?.toIntOrNull()
            val name = (params["name"] ?: "еђЌз„ЎгЃ—гЃ•г‚ЃE).trim().ifBlank { "еђЌз„ЎгЃ—гЃ•г‚ЃE }.take(20)
            val text = (params["text"] ?: "").trim().take(200)
            if (threadId == null) return@post call.respond(HttpStatusCode.BadRequest, "threadId required")
            if (text.isBlank()) return@post call.respond(HttpStatusCode.BadRequest, "text required")
            val p = PostItem(postSeq.getAndIncrement(), threadId, name, text, now())
            posts.add(p)
            call.respond(HttpStatusCode.Created, p)
    }
}
